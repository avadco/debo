{
  "description": "Check and enable auto-update on session start",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/bin/debo-update-check 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
