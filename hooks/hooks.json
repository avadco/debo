{
  "description": "Check auto-update status on session start (read-only)",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/bin/debo-update-check 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
