#!/usr/bin/env bash
# debo-update-check — check and enable autoUpdate on first run.
#
# First run: enables autoUpdate in settings.json + known_marketplaces.json, creates marker.
# Subsequent runs: reads only, outputs status to stdout for context.
set -euo pipefail

MARKETPLACE_ID="avadco-debo"
SETTINGS_FILE="$HOME/.claude/settings.json"
KNOWN_FILE="$HOME/.claude/plugins/known_marketplaces.json"
STATE_DIR="${CLAUDE_PLUGIN_DATA:-$HOME/.debo}"
OUT_FILE="$STATE_DIR/debo-update.json"
MARKER="$STATE_DIR/.auto-update-done"

mkdir -p "$STATE_DIR"

# ─── Detect JSON tool ────────────────────────────────────────
if command -v jq >/dev/null 2>&1; then
  JSON_TOOL="jq"
elif command -v python3 >/dev/null 2>&1; then
  JSON_TOOL="python3"
elif command -v python >/dev/null 2>&1; then
  JSON_TOOL="python"
elif command -v node >/dev/null 2>&1; then
  JSON_TOOL="node"
else
  echo '{"autoUpdate":false}' > "$OUT_FILE"
  echo "DEBO_AUTO_UPDATE=false"
  exit 0
fi

# ─── json_read ───────────────────────────────────────────────
json_read() {
  local file="$1" key_path="$2"
  case "$JSON_TOOL" in
    jq)
      jq -r "$key_path" "$file" 2>/dev/null || echo "null"
      ;;
    python3|python)
      _JR_FILE="$file" _JR_KEY="$key_path" "$JSON_TOOL" -c '
import json, os
try:
    d = json.load(open(os.environ["_JR_FILE"]))
    keys = os.environ["_JR_KEY"].lstrip(".").replace(chr(34),"").split(".")
    for k in keys:
        d = d[k]
    print(str(d).lower())
except: print("null")
' 2>/dev/null || echo "null"
      ;;
    node)
      _JR_FILE="$file" _JR_KEY="$key_path" node -e '
try {
  let d = JSON.parse(require("fs").readFileSync(process.env._JR_FILE,"utf8"));
  const keys = process.env._JR_KEY.replace(/^\./,"").replace(/"/g,"").split(".");
  for (const k of keys) d = d[k];
  console.log(String(d).toLowerCase());
} catch(e) { console.log("null"); }
' 2>/dev/null || echo "null"
      ;;
  esac
}

# ─── json_set ────────────────────────────────────────────────
json_set() {
  local file="$1" key_path="$2" value="$3"
  local tmp="${file}.tmp.$$"
  case "$JSON_TOOL" in
    jq)
      if jq "$key_path = $value" "$file" > "$tmp" 2>/dev/null; then
        mv "$tmp" "$file"; return 0
      fi
      rm -f "$tmp"; return 1
      ;;
    python3|python)
      _JS_FILE="$file" _JS_KEY="$key_path" _JS_VAL="$value" _JS_TMP="$tmp" \
      "$JSON_TOOL" -c '
import json, os
f = os.environ["_JS_FILE"]
with open(f) as fh: d = json.load(fh)
keys = os.environ["_JS_KEY"].lstrip(".").replace(chr(34),"").split(".")
obj = d
for k in keys[:-1]:
    if k not in obj or not isinstance(obj[k], dict):
        obj[k] = {}
    obj = obj[k]
obj[keys[-1]] = json.loads(os.environ["_JS_VAL"])
with open(os.environ["_JS_TMP"],"w") as fh: json.dump(d, fh, indent=2)
' 2>/dev/null && mv "$tmp" "$file" && return 0
      rm -f "$tmp"; return 1
      ;;
    node)
      _JS_FILE="$file" _JS_KEY="$key_path" _JS_VAL="$value" _JS_TMP="$tmp" \
      node -e '
const fs = require("fs");
let d = JSON.parse(fs.readFileSync(process.env._JS_FILE,"utf8"));
const keys = process.env._JS_KEY.replace(/^\./,"").replace(/"/g,"").split(".");
let obj = d;
for (let i = 0; i < keys.length - 1; i++) {
  if (!obj[keys[i]] || typeof obj[keys[i]] !== "object") obj[keys[i]] = {};
  obj = obj[keys[i]];
}
obj[keys[keys.length-1]] = JSON.parse(process.env._JS_VAL);
fs.writeFileSync(process.env._JS_TMP, JSON.stringify(d, null, 2));
' 2>/dev/null && mv "$tmp" "$file" && return 0
      rm -f "$tmp"; return 1
      ;;
  esac
}

# ─── First run: enable autoUpdate directly ───────────────────
if [ ! -f "$MARKER" ]; then
  [ -f "$SETTINGS_FILE" ] && json_set "$SETTINGS_FILE" \
    ".extraKnownMarketplaces.\"$MARKETPLACE_ID\".autoUpdate" "true" 2>/dev/null || true
  [ -f "$KNOWN_FILE" ] && json_set "$KNOWN_FILE" \
    ".\"$MARKETPLACE_ID\".autoUpdate" "true" 2>/dev/null || true
  touch "$MARKER"
fi

# ─── Check current state ─────────────────────────────────────
ok="true"

if [ -f "$SETTINGS_FILE" ]; then
  val="$(json_read "$SETTINGS_FILE" ".extraKnownMarketplaces.\"$MARKETPLACE_ID\".autoUpdate")"
  [ "$val" != "true" ] && ok="false"
else
  ok="false"
fi

if [ "$ok" = "true" ] && [ -f "$KNOWN_FILE" ]; then
  val="$(json_read "$KNOWN_FILE" ".\"$MARKETPLACE_ID\".autoUpdate")"
  [ "$val" != "true" ] && ok="false"
fi

# ─── Output ──────────────────────────────────────────────────
echo "{\"autoUpdate\":$ok}" > "$OUT_FILE"
echo "DEBO_AUTO_UPDATE=$ok"
