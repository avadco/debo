#!/usr/bin/env bash
# debo-update-check — READ-ONLY check, writes result to plugin data dir only.
#
# Checks if autoUpdate is enabled in settings.json and known_marketplaces.json.
# Writes {"autoUpdate": true/false} to ${CLAUDE_PLUGIN_DATA}/debo-update.json
# NEVER modifies user settings files.
set -euo pipefail

MARKETPLACE_ID="avadco-debo"
SETTINGS_FILE="$HOME/.claude/settings.json"
KNOWN_FILE="$HOME/.claude/plugins/known_marketplaces.json"
STATE_DIR="${CLAUDE_PLUGIN_DATA:-$HOME/.debo}"
OUT_FILE="$STATE_DIR/debo-update.json"

# ─── Detect JSON tool ────────────────────────────────────────
if command -v jq >/dev/null 2>&1; then
  JSON_TOOL="jq"
elif command -v python3 >/dev/null 2>&1; then
  JSON_TOOL="python3"
elif command -v python >/dev/null 2>&1; then
  JSON_TOOL="python"
elif command -v node >/dev/null 2>&1; then
  JSON_TOOL="node"
else
  mkdir -p "$STATE_DIR"
  echo '{"autoUpdate":false}' > "$OUT_FILE"
  exit 0
fi

# ─── json_read ───────────────────────────────────────────────
json_read() {
  local file="$1" key_path="$2"
  case "$JSON_TOOL" in
    jq)
      jq -r "$key_path" "$file" 2>/dev/null || echo "null"
      ;;
    python3|python)
      _JR_FILE="$file" _JR_KEY="$key_path" "$JSON_TOOL" -c '
import json, os
try:
    d = json.load(open(os.environ["_JR_FILE"]))
    keys = os.environ["_JR_KEY"].lstrip(".").replace(chr(34),"").split(".")
    for k in keys:
        d = d[k]
    print(str(d).lower())
except: print("null")
' 2>/dev/null || echo "null"
      ;;
    node)
      _JR_FILE="$file" _JR_KEY="$key_path" node -e '
try {
  let d = JSON.parse(require("fs").readFileSync(process.env._JR_FILE,"utf8"));
  const keys = process.env._JR_KEY.replace(/^\./,"").replace(/"/g,"").split(".");
  for (const k of keys) d = d[k];
  console.log(String(d).toLowerCase());
} catch(e) { console.log("null"); }
' 2>/dev/null || echo "null"
      ;;
  esac
}

# ─── Check (read-only) ──────────────────────────────────────
ok="true"

if [ -f "$SETTINGS_FILE" ]; then
  val="$(json_read "$SETTINGS_FILE" ".extraKnownMarketplaces.\"$MARKETPLACE_ID\".autoUpdate")"
  [ "$val" != "true" ] && ok="false"
else
  ok="false"
fi

if [ "$ok" = "true" ] && [ -f "$KNOWN_FILE" ]; then
  val="$(json_read "$KNOWN_FILE" ".\"$MARKETPLACE_ID\".autoUpdate")"
  [ "$val" != "true" ] && ok="false"
fi

# ─── Write result to plugin data dir (allowed) ──────────────
mkdir -p "$STATE_DIR"
echo "{\"autoUpdate\":$ok}" > "$OUT_FILE"
