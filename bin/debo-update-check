#!/usr/bin/env bash
# debo-update-check — READ-ONLY check if autoUpdate is enabled.
#
# Output (one line):
#   AUTO_UPDATE_OK         — autoUpdate is true in both files
#   AUTO_UPDATE_DISABLED   — autoUpdate is not enabled (suggest /debo:update-settings)
#   AUTO_UPDATE_SKIP       — files not found or no JSON tool
#
# This script NEVER modifies user files. If auto-update is not enabled,
# it outputs AUTO_UPDATE_DISABLED so Claude can suggest the update-settings skill.
set -euo pipefail

MARKETPLACE_ID="avadco-debo"
SETTINGS_FILE="$HOME/.claude/settings.json"
KNOWN_FILE="$HOME/.claude/plugins/known_marketplaces.json"

# ─── Detect a working JSON tool (jq, python3, python, node) ────
if command -v jq >/dev/null 2>&1; then
  JSON_TOOL="jq"
elif command -v python3 >/dev/null 2>&1; then
  JSON_TOOL="python3"
elif command -v python >/dev/null 2>&1; then
  JSON_TOOL="python"
elif command -v node >/dev/null 2>&1; then
  JSON_TOOL="node"
else
  echo "AUTO_UPDATE_SKIP"
  exit 0
fi

# ─── json_read <file> <dotted.key.path> ──────────────────────
# Reads a nested JSON value. Returns "true", "false", "null", etc.
json_read() {
  local file="$1" key_path="$2"
  case "$JSON_TOOL" in
    jq)
      jq -r "$key_path" "$file" 2>/dev/null || echo "null"
      ;;
    python3|python)
      _JR_FILE="$file" _JR_KEY="$key_path" "$JSON_TOOL" -c '
import json, os
try:
    d = json.load(open(os.environ["_JR_FILE"]))
    keys = os.environ["_JR_KEY"].lstrip(".").replace(chr(34),"").split(".")
    for k in keys:
        d = d[k]
    print(str(d).lower())
except: print("null")
' 2>/dev/null || echo "null"
      ;;
    node)
      _JR_FILE="$file" _JR_KEY="$key_path" node -e '
try {
  let d = JSON.parse(require("fs").readFileSync(process.env._JR_FILE,"utf8"));
  const keys = process.env._JR_KEY.replace(/^\./,"").replace(/"/g,"").split(".");
  for (const k of keys) d = d[k];
  console.log(String(d).toLowerCase());
} catch(e) { console.log("null"); }
' 2>/dev/null || echo "null"
      ;;
  esac
}

# ─── Check both files (read-only) ────────────────────────────
settings_ok="true"
known_ok="true"

if [ -f "$SETTINGS_FILE" ]; then
  val="$(json_read "$SETTINGS_FILE" ".extraKnownMarketplaces.\"$MARKETPLACE_ID\".autoUpdate")"
  [ "$val" != "true" ] && settings_ok="false"
else
  settings_ok="false"
fi

if [ -f "$KNOWN_FILE" ]; then
  val="$(json_read "$KNOWN_FILE" ".\"$MARKETPLACE_ID\".autoUpdate")"
  [ "$val" != "true" ] && known_ok="false"
else
  known_ok="false"
fi

if [ "$settings_ok" = "true" ] && [ "$known_ok" = "true" ]; then
  echo "AUTO_UPDATE_OK"
else
  echo "AUTO_UPDATE_DISABLED"
fi
